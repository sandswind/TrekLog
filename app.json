{
  "expo": {
    "name": "TrekLog",
    "slug": "treklog",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "treklog",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.sandswind.treklog",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "TrekLog needs microphone access to record your Captain's Log entries.",
        "NSFaceIDUsageDescription": "Use Face ID to unlock your private log entries."
      }
    },
    "android": {
      "package": "com.sandswind.treklog",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#03060F"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "web": { "favicon": "./assets/favicon.png" },
    "plugins": [
      "expo-sqlite",
      "expo-sharing",
      "expo-status-bar",
      ["expo-av", { "microphonePermission": "TrekLog needs microphone access to record your Captain's Log." }],
      ["expo-local-authentication", { "faceIDPermission": "Allow TrekLog to use Face ID to protect your private log entries." }]
    ],
    "extra": { "eas": { "projectId": "treklog-v1" } }
  }
}
